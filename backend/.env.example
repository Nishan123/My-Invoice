# Copy this file to .env and fill in real values:  cp .env.example .env

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (local Mongo or an Atlas connection string)
MONGODB_URI=mongodb://localhost:27017/invoicesathi

# Auth
JWT_SECRET=
JWT_EXPIRE=7d
COOKIE_SECRET=

# Logging
LOG_LEVEL=info

# Security
CSP_ENABLED=true

# Number of reverse proxies in front of the app (e.g. 1 behind nginx/Heroku) so
# rate limiting keys on the real client IP. Leave unset when running directly.
# TRUST_PROXY_HOPS=1
